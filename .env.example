# Supabase personal project (dashboard: Settings -> API)
# Only these two values ship to the client. AI keys (ANTHROPIC_API_KEY, FAL_KEY)
# live as Supabase edge function secrets, never here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here
