{
  "expo": {
    "name": "Mufradat",
    "slug": "arabic-study",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arabicstudy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.rehanmohideen.mufradat",
      "buildNumber": "1",
      "supportsTablet": false,
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.rehanmohideen.mufradat",
      "adaptiveIcon": {
        "backgroundColor": "#0D7A6C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D7A6C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mufradat needs access to your photos so you can turn pictures of your workbook pages into flashcards.",
          "cameraPermission": "Mufradat uses the camera to photograph your workbook pages and turn them into flashcards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
